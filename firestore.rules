
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Funciones de utilidad
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Reglas para usuarios y sus subcolecciones
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      match /appointments/{appointmentId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Unicidad de identificaciones
    match /identifications/{idNumber} {
      // Permitir leer para verificar existencia durante registro
      allow read: if true; 
      // Solo el usuario puede crear su entrada de identificación
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // Reglas para centros de salud (lectura pública para el catálogo)
    match /healthCenters/{healthCenterId} {
      allow read: if true;
      allow write: if false; // Solo administradores vía consola
    }

    // Denegar todo lo demás por defecto
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
